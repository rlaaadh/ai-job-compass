# National Pension Service OpenAPI key
NPS_API_KEY=your_nps_api_key_here

# Anthropic API key (for AI report generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Public anon key for client-side SDK usage
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only key for backend/admin usage
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Postgres connection string for FastAPI / SQLAlchemy
# For Vercel or serverless-style traffic, prefer a pooled connection string.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres
